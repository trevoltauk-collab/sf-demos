package com.insurance.excel.model;

import lombok.Data;
import java.util.List;
import java.util.Map;

/**
 * Extended mapping config model supporting:
 *
 *  Spacing      — configurable row/column gaps between plans and between benefit groups
 *  Formula skip — cells within data regions that must be left untouched (contain template formulas)
 *  Merge        — benefit category headers and plan name headers that span across rows/columns
 *  Composite    — multi-field cell values assembled from several JSON fields with a separator
 *
 * Mapping types:
 *   CELL         scalar JsonPath → single cell
 *   CELL_EXPR    expression result → single cell
 *   LIST         JSON array → repeating rows (one item per row, variable step, gap rows)
 *   MULTI_COL    JSON array items → parallel columns (plan comparison grid)
 *   GROUPED_LIST JSON array grouped by a key → category-header row + detail rows per group
 *   MERGE_HEADER Span a value across merged cells (row or column span)
 */
@Data
public class TemplateMappingConfig {

    private TemplateInfo template;
    private List<SheetMapping> sheets;

    @Data
    public static class TemplateInfo {
        private String id;
        private String file;
        private String description;
    }

    @Data
    public static class SheetMapping {
        private String name;
        private List<CellMapping> mappings;
    }

    @Data
    public static class CellMapping {
        private String id;
        private MappingType type;

        // Scalar (CELL / CELL_EXPR)
        private String cell;
        private String jsonPath;
        private String expression;
        private DataType dataType;
        private String format;

        // LIST / GROUPED_LIST / MULTI_COL shared
        private Integer startRow;
        private Integer rowStepSize;
        private boolean preserveRowStyle = true;
        private boolean insertRowsIfNeeded = false;
        private List<ColumnDef> columns;

        // Spacing
        private int gapRows = 0;        // blank rows inserted between each item
        private int columnGap = 0;      // blank columns between each plan column
        private String startCol;        // anchor column for auto columnGap calculation

        // Formula skip: column letters (or "col:rowOffset") to leave untouched
        private List<String> skipFormulaCols;

        // Merge-centred headers
        private MergeSpec merge;                 // for MERGE_HEADER type
        private List<RowMergeSpec> rowMerges;    // per-item merges in LIST/GROUPED_LIST

        // MULTI_COL: explicit index→column map (overrides startCol+columnGap)
        private Map<Integer, String> columnMapping;

        // GROUPED_LIST
        private String groupByField;
        private List<ColumnDef> groupHeaderColumns;
        private Integer groupHeaderStyleRow;
        private String mergeHeaderCols;          // "B:G" → merge this range on each header row
    }

    @Data
    public static class ColumnDef {
        private String col;
        private String field;
        private DataType dataType;
        private String format;
        private String formula;             // "=D{ROW}*12"
        private CompositeSpec composite;    // multi-field assembly
        private int rowOffset = 0;          // row offset within item block (multi-row items)
        private boolean mergeCell = false;
        private int colSpan = 1;
        private int rowSpan = 1;
    }

    @Data
    public static class CompositeSpec {
        /**
         * Parts list — each entry is either:
         *   "$fieldName"    resolved from JSON item (dot-notation supported)
         *   "literal text"  written as-is
         */
        private List<String> parts;
        private String separator = "";
        private String numericFormat;       // format applied to numeric values before concat
    }

    @Data
    public static class MergeSpec {
        private String startCell;           // "C7"
        private String endCell;             // "F7"
        private String value;               // static value
        private String jsonPath;            // dynamic value
        private DataType dataType;
        private String format;
        private String align = "CENTER";    // CENTER | LEFT | RIGHT
    }

    @Data
    public static class RowMergeSpec {
        private int rowOffset = 0;          // 0-based within item block
        private String startCol;
        private String endCol;
    }

    public enum MappingType {
        CELL, CELL_EXPR, LIST, MULTI_COL, GROUPED_LIST, MERGE_HEADER
    }

    public enum DataType {
        STRING, NUMBER, CURRENCY, PERCENTAGE, DATE, BOOLEAN
    }
}